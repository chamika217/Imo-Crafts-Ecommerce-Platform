    {
      "name": "Custom Inquiries",
      "item": [
        {
          "name": "Create Inquiry (Public - Custom Order)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerInfo\": {\n    \"name\": \"Nimasha Silva\",\n    \"phone\": \"0719876543\",\n    \"email\": \"nimasha@example.com\"\n  },\n  \"eventDate\": \"2026-07-15\",\n  \"description\": \"Need a custom birthday decoration set with pink and gold theme for a 25th birthday party.\",\n  \"budget\": \"5000-8000\",\n  \"quantity\": \"1 set\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/inquiries",
              "host": ["{{baseUrl}}"],
              "path": ["inquiries"]
            },
            "description": "Submit a custom order inquiry. Public endpoint used by the Custom Order page."
          },
          "response": []
        },
        {
          "name": "Get All Inquiries (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/inquiries",
              "host": ["{{baseUrl}}"],
              "path": ["inquiries"]
            },
            "description": "Get all custom order inquiries. Optional query param: status. Requires Firebase admin Bearer token."
          },
          "response": []
        },
        {
          "name": "Get Single Inquiry (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/inquiries/{{inquiryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["inquiries", "{{inquiryId}}"]
            },
            "description": "Get a single inquiry by ID. Requires Firebase admin Bearer token."
          },
          "response": []
        },
        {
          "name": "Update Inquiry Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Quoted\",\n  \"adminNotes\": \"Quoted Rs. 6500 for the full set, awaiting customer confirmation.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/inquiries/{{inquiryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["inquiries", "{{inquiryId}}"]
