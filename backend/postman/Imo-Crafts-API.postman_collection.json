    {
      "name": "Upload (Cloudinary)",
      "item": [
        {
          "name": "Upload Image (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/upload",
              "host": ["{{baseUrl}}"],
              "path": ["upload"]
            },
            "description": "Upload an image to Cloudinary. Select a file under form-data 'image' key. Requires Firebase admin Bearer token. Returns { url, publicId }."
          },
          "response": []
        },
        {
          "name": "Delete Image (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/upload/imo-crafts%2Fsample-public-id",
              "host": ["{{baseUrl}}"],
              "path": ["upload", "imo-crafts%2Fsample-public-id"]
            },
            "description": "Delete an image from Cloudinary by its URL-encoded publicId (e.g. imo-crafts/abc123). Requires Firebase admin Bearer token."
          },
          "response": []
        }
      ]
    }
  ]
